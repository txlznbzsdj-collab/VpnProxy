<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- ========= ANIMATED BACKGROUND PARTICLES LAYER ========= -->
    <View
        android:id="@+id/particleLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3" />

    <!-- ========= TOP BAR ========= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#E0E0E0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/serverSelectorIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_card_glass"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_globe"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ========= ANIMATED GLOW RING 1 (outer) ========= -->
    <ImageView
        android:id="@+id/glowRing1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/bg_glow_ring"
        android:alpha="0.3"
        android:translationZ="0dp"
        app:layout_constraintBottom_toBottomOf="@id/statusIndicator"
        app:layout_constraintEnd_toEndOf="@id/statusIndicator"
        app:layout_constraintStart_toStartOf="@id/statusIndicator"
        app:layout_constraintTop_toTopOf="@id/statusIndicator" />

    <!-- ========= ANIMATED GLOW RING 2 (inner) ========= -->
    <ImageView
        android:id="@+id/glowRing2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/bg_glow_ring"
        android:alpha="0.5"
        android:translationZ="1dp"
        app:layout_constraintBottom_toBottomOf="@id/statusIndicator"
        app:layout_constraintEnd_toEndOf="@id/statusIndicator"
        app:layout_constraintStart_toStartOf="@id/statusIndicator"
        app:layout_constraintTop_toTopOf="@id/statusIndicator" />

    <!-- ========= STATUS INDICATOR ========= -->
    <FrameLayout
        android:id="@+id/statusIndicator"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <ImageView
            android:id="@+id/statusPulse"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/bg_status_pulse_off"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/statusGlowOverlay"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:src="@drawable/bg_glow_ring"
            android:alpha="0.6"
            android:scaleX="1.2"
            android:scaleY="1.2"
            android:translationZ="-1dp" />

        <ImageView
            android:id="@+id/statusIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_shield"
            android:alpha="0.9" />

    </FrameLayout>

    <!-- ========= STATUS TEXT ========= -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/status_disconnected"
        android:textColor="#F44336"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusIndicator" />

    <TextView
        android:id="@+id/statusSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="点击连接以保护您的连接"
        android:textColor="#78909C"
        android:textSize="14sp"
        android:letterSpacing="0.01"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusText" />

    <!-- ========= SERVER INFO GLASS CARD ========= -->
    <androidx.cardview.widget.CardView
        android:id="@+id/serverCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="28dp"
        android:backgroundTint="#1AFFFFFF"
        android:elevation="4dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusSubText">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/serverIconCard"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_globe"
                app:layout_constraintBottom_toBottomOf="@id/serverLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/serverLabel" />

            <TextView
                android:id="@+id/serverLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="服务器"
                android:textColor="#90A4AE"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/serverIconCard"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/serverName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="选择服务器..."
                android:textColor="#ECEFF1"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/serverLabel"
                app:layout_constraintTop_toBottomOf="@id/serverLabel" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- ========= TRAFFIC STATS GLASS CARD ========= -->
    <androidx.cardview.widget.CardView
        android:id="@+id/statsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#1AFFFFFF"
        android:elevation="4dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/serverCard">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Upload Speed -->
            <ImageView
                android:id="@+id/uploadIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_upward"
                app:layout_constraintBottom_toBottomOf="@id/uploadLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/uploadLabel" />

            <TextView
                android:id="@+id/uploadLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="上传"
                android:textColor="#78909C"
                android:textSize="12sp"
                app:layout_constraintStart_toEndOf="@id/uploadIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/uploadSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="26dp"
                android:text="0 B/s"
                android:textColor="#4CAF50"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/uploadIcon"
                app:layout_constraintTop_toBottomOf="@id/uploadLabel" />

            <TextView
                android:id="@+id/uploadTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="总计: 0 B"
                android:textColor="#546E7A"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/uploadSpeed"
                app:layout_constraintTop_toBottomOf="@id/uploadSpeed" />

            <!-- Divider -->
            <View
                android:id="@+id/statsDivider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#26FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/uploadTotal" />

            <!-- Download Speed -->
            <ImageView
                android:id="@+id/downloadIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="12dp"
                android:src="@drawable/ic_arrow_downward"
                app:layout_constraintBottom_toBottomOf="@id/downloadLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/downloadLabel" />

            <TextView
                android:id="@+id/downloadLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="12dp"
                android:text="下载"
                android:textColor="#78909C"
                android:textSize="12sp"
                app:layout_constraintStart_toEndOf="@id/downloadIcon"
                app:layout_constraintTop_toBottomOf="@id/statsDivider" />

            <TextView
                android:id="@+id/downloadSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="26dp"
                android:text="0 B/s"
                android:textColor="#26A69A"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/downloadIcon"
                app:layout_constraintTop_toBottomOf="@id/downloadLabel" />

            <TextView
                android:id="@+id/downloadTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="总计: 0 B"
                android:textColor="#546E7A"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/downloadSpeed"
                app:layout_constraintTop_toBottomOf="@id/downloadSpeed" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- ========= CONNECT BUTTON ========= -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/connectButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#FF4CAF50"
        android:elevation="8dp"
        android:stateListAnimator="@null"
        android:text="@string/connect"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="#33FFFFFF" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/connectionProgress"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:alpha="0"
        android:indeterminate="true"
        app:layout_constraintBottom_toBottomOf="@id/connectButton"
        app:layout_constraintEnd_toEndOf="@id/connectButton"
        app:layout_constraintStart_toStartOf="@id/connectButton"
        app:trackColor="#00FFFFFF"
        app:indicatorColor="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>
